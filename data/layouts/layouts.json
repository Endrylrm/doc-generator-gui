{
    "Cartucho": {
		"user_interface": {
			"name": {
				"type": "name",
				"required": true,
				"description": "Nome do Funcionário (Obrigatório):",
				"placeholder": "Digite o nome do funcionário...",
				"error_message": "Nome do funcionário",
				"template": "name"
			},
			"cpf": {
				"type": "cpf",
				"required": true,
				"description": "CPF / CNPJ do Funcionário (Obrigatório):",
				"placeholder": "Observação: Digite apenas os números do CPF ou CNPJ, formatação automática.",
				"error_message": "CPF / CNPJ do funcionário",
				"template": "cpf"
			},
			"cartucho": {
				"type": "cartucho",
				"required": true,
				"description": "Cartucho de Impressora do Funcionário (Obrigatório):",
				"placeholder": "Digite o cartucho de impressora a ser entregue ao funcionário...",
				"error_message": "Cartucho de Impressora do Funcionário",
				"template": "cartucho"
			},
			"impressora": {
				"type": "impressora",
				"required": true,
				"description": "Modelo de impressora do Funcionário (Obrigatório):",
				"placeholder": "Digite o modelo de impressora que será usado esse cartucho...",
				"error_message": "Modelo de impressora do Funcionário",
				"template": "impressora"
			},
			"remark": {
				"type": "remark",
				"required": false,
				"description": "Observação (Opcional):",
				"placeholder": "Digite uma observação referente a esse cartucho de impressora...",
				"error_message": "Observação do Cartucho de impressora do Funcionário",
				"template": "obs"
			}
		},
		"config": {
            "document_template": "termo_cartucho.html",
			"output": "./documents/Termo de Entrega de Cartucho"
		}
    },
